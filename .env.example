# SignalHub local environment template
# Copy this file to `.env` before running locally.
# Do not commit your real `.env`.

APP_NAME="SignalHub - Virtuals Monitor"
SIGNALHUB_DB_PATH=signalhub.db
DASHBOARD_PATH=signalhub/ui/dashboard/index.html
TOKEN_POOL_EXPORT_PATH=exports/token-pools.json

SOURCE_ENABLED=true
SOURCE_NAME=virtuals_projects
SOURCE_TYPE=http_polling

POLL_INTERVAL_SECONDS=30
REQUEST_TIMEOUT_SECONDS=15

VIRTUALS_ENDPOINT=https://api2.virtuals.io/api/virtuals
VIRTUALS_APP_BASE_URL=https://app.virtuals.io
VIRTUALS_MODE=upcoming_launches
VIRTUALS_PAGE_SIZE=100
VIRTUALS_PAGES=2
VIRTUALS_DETAIL_REFRESH_LIMIT=50
VIRTUALS_SORT=launchedAt:asc
VIRTUALS_POPULATE=image,creator
VIRTUALS_STATUSES=
VIRTUALS_CATEGORIES=
VIRTUALS_CHAIN=
VIRTUALS_HEADERS={}
VIRTUALS_SAMPLE_MODE=false
SAMPLE_DATA_PATH=sample_data/virtuals_projects.json

# Base / Chainstack RPC
# Example HTTPS: https://base-mainnet.core.chainstack.com/<your-project-id>
# Example WSS:   wss://base-mainnet.core.chainstack.com/<your-project-id>
CHAINSTACK_BASE_HTTPS_URL=https://base-mainnet.core.chainstack.com/<your-project-id>
CHAINSTACK_BASE_WSS_URL=wss://base-mainnet.core.chainstack.com/<your-project-id>
CHAINSTACK_SUBSCRIPTION_ENABLED=true
CHAINSTACK_SUBSCRIPTION_REFRESH_SECONDS=30
CHAINSTACK_TRACE_BACKFILL_ENABLED=true
CHAINSTACK_TRACE_BACKFILL_BATCH_SIZE=6
CHAINSTACK_TRACE_BACKFILL_COOLDOWN_SECONDS=180
CHAINSTACK_LOG_CHUNK_SIZE=100
CHAINSTACK_EARLIEST_SCAN_WINDOW_BLOCKS=3000
CHAINSTACK_EARLIEST_BATCH_SIZE=12
CHAINSTACK_PATTERN_LOG_LIMIT=3
CHAINSTACK_PRELAUNCH_STATUSES=PRE LAUNCH,PRE_LAUNCH,PRELAUNCH

# Optional legacy explorer fallback
BASESCAN_API_KEY=
ETHERSCAN_API_KEY=
ETHERSCAN_BASE_API_URL=https://api.etherscan.io/v2/api
BASE_CHAIN_ID=8453

# Optional deployment target metadata
# These values are not used by the runtime app today.
# Keep real credentials only in your local `.env`, never commit them.
DEPLOY_DOMAIN=signal.licheng.website
DEPLOY_SERVER_IP=66.63.173.143
DEPLOY_SSH_PORT=22
DEPLOY_SSH_USERNAME=root
DEPLOY_SSH_AUTH_MODE=password
DEPLOY_SSH_PASSWORD=
DEPLOY_SSH_PRIVATE_KEY_PATH=
DEPLOY_APP_DIR=/opt/signalhub
DEPLOY_SERVICE_NAME=signalhub
DEPLOY_PUBLIC_BASE_URL=https://signal.licheng.website
DEPLOY_UPSTREAM_HOST=127.0.0.1
DEPLOY_UPSTREAM_PORT=8000
